import pandas as pd
import numpy as np

try:
    from nba.model_validation.probability_safety_filters_b003 import apply_probability_safety_filters
except ModuleNotFoundError:
    from probability_safety_filters_b003 import apply_probability_safety_filters

# -----------------------------
# LOAD DATA
# -----------------------------
df = pd.read_json("data/predictions_log.json")  # your stored predictions

df['date'] = pd.to_datetime(df['prediction_date'])
df = df.sort_values('date')

# -----------------------------
# ODDS + BANKROLL HELPERS
# -----------------------------
def american_to_decimal(odds):
    if odds is None or pd.isna(odds):
        return np.nan
    odds = float(odds)
    if odds > 0:
        return 1 + odds / 100
    if odds < 0:
        return 1 + 100 / abs(odds)
    return np.nan


def simulate_bankroll(results, starting_bankroll=1000.0, flat_unit=10.0, active_only=True):
    sim = results.copy().sort_values('date')

    if active_only and 'skip_bet' in sim.columns:
        sim = sim[sim['skip_bet'] == False]

    if sim.empty:
        return sim, {
            'starting_bankroll': starting_bankroll,
            'ending_bankroll': starting_bankroll,
            'profit': 0.0,
            'roi': np.nan,
            'max_drawdown': 0.0,
            'bets': 0
        }

    if 'market_price' not in sim.columns:
        sim['market_price'] = -110

    sim['decimal_odds'] = sim['market_price'].apply(american_to_decimal).fillna(1.91)
    sim['stake'] = flat_unit
    sim['profit'] = np.where(
        sim['actual'] == 1,
        sim['stake'] * (sim['decimal_odds'] - 1),
        -sim['stake']
    )

    sim['bankroll'] = starting_bankroll + sim['profit'].cumsum()
    sim['peak_bankroll'] = sim['bankroll'].cummax()
    sim['drawdown'] = sim['bankroll'] - sim['peak_bankroll']

    total_staked = sim['stake'].sum()
    total_profit = sim['profit'].sum()

    summary = {
        'starting_bankroll': float(starting_bankroll),
        'ending_bankroll': float(sim['bankroll'].iloc[-1]),
        'profit': float(total_profit),
        'roi': float(total_profit / total_staked) if total_staked else np.nan,
        'max_drawdown': float(sim['drawdown'].min()),
        'bets': int(len(sim)),
        'wins': int((sim['actual'] == 1).sum()),
        'losses': int((sim['actual'] == 0).sum()),
        'hit_rate': float((sim['actual'] == 1).mean()),
        'total_staked': float(total_staked)
    }

    return sim, summary

# -----------------------------
# SAFETY FILTER HELPERS
# -----------------------------
def apply_b003_filters_to_row(row):
    row_dict = row.to_dict()
    row_dict['pred_prob'] = row_dict.get('sharpedge_prob', row_dict.get('model_probability', 0.50))
    row_dict['rebound_prob'] = row_dict.get('rebound_prob', row_dict['pred_prob'])

    result = apply_probability_safety_filters(row_dict)

    return pd.Series({
        'sharpedge_prob_filtered': result.pred_prob,
        'rebound_prob_filtered': result.rebound_prob,
        'downgrade_prob_filtered': result.downgrade_prob,
        'skip_bet': result.skip_bet,
        'safety_filter_tags': '|'.join(result.tags),
        'safety_filter_notes': '|'.join(result.notes)
    })

# -----------------------------
# EXPANDING WINDOW SPLIT
# -----------------------------
def expanding_window_backtest(df, start_date, use_filtered=True):
    results = []

    unique_dates = sorted(df['date'].unique())

    for current_date in unique_dates:
        if current_date <= pd.to_datetime(start_date):
            continue

        train = df[df['date'] < current_date]
        test = df[df['date'] == current_date]

        if len(train) < 50:
            continue

        # Baseline model = historical hit rate by player.
        player_stats = train.groupby('player')['hit'].mean()

        for _, row in test.iterrows():
            baseline_prob = player_stats.get(row['player'], 0.5)

            if use_filtered and 'sharpedge_prob_filtered' in row.index:
                pred_prob = row.get('sharpedge_prob_filtered', baseline_prob)
                skip_bet = bool(row.get('skip_bet', False))
            elif 'sharpedge_prob' in row.index:
                pred_prob = row.get('sharpedge_prob', baseline_prob)
                skip_bet = False
            else:
                pred_prob = baseline_prob
                skip_bet = False

            results.append({
                "date": current_date,
                "player": row['player'],
                "actual": row['hit'],
                "baseline_prob": baseline_prob,
                "predicted_prob": pred_prob,
                "skip_bet": skip_bet,
                "market_price": row.get('market_price', -110),
                "safety_filter_tags": row.get('safety_filter_tags', '')
            })

    return pd.DataFrame(results)

# -----------------------------
# SHARPEDGE FEATURE LAYER
# -----------------------------
def sharpedge_weighted_probability(row):
    """
    Hybrid SharpEdge probability blend.

    Required optional columns:
    - season_baseline_prob
    - last10_prob
    - h2h_prob
    - postmortem_adjustment

    If a column is missing, the runner falls back to neutral 0.50
    so the script can still run on early datasets.
    """
    season_baseline_prob = row.get('season_baseline_prob', 0.50)
    last10_prob = row.get('last10_prob', 0.50)
    h2h_prob = row.get('h2h_prob', 0.50)
    postmortem_adjustment = row.get('postmortem_adjustment', 0.00)

    pred_prob = (
        0.45 * season_baseline_prob +
        0.30 * last10_prob +
        0.15 * h2h_prob +
        0.10 * postmortem_adjustment
    )

    return float(np.clip(pred_prob, 0.01, 0.99))

if not df.empty:
    df['sharpedge_prob'] = df.apply(sharpedge_weighted_probability, axis=1)

    filter_columns = df.apply(apply_b003_filters_to_row, axis=1)
    df = pd.concat([df, filter_columns], axis=1)

# -----------------------------
# RUN BACKTESTS
# -----------------------------
raw_results = expanding_window_backtest(df, "2026-03-01", use_filtered=False)
filtered_results = expanding_window_backtest(df, "2026-03-01", use_filtered=True)

# -----------------------------
# EVALUATION
# -----------------------------
def evaluate(results, active_only=False):
    eval_df = results.copy()

    if active_only and 'skip_bet' in eval_df.columns:
        eval_df = eval_df[eval_df['skip_bet'] == False]

    if eval_df.empty:
        return {
            "accuracy": np.nan,
            "brier_score": np.nan,
            "total_samples": 0,
            "skipped_samples": int(results['skip_bet'].sum()) if 'skip_bet' in results.columns else 0
        }

    eval_df['predicted'] = eval_df['predicted_prob'] > 0.5

    accuracy = (eval_df['predicted'] == eval_df['actual']).mean()
    brier = np.mean((eval_df['predicted_prob'] - eval_df['actual'])**2)

    return {
        "accuracy": accuracy,
        "brier_score": brier,
        "total_samples": len(eval_df),
        "skipped_samples": int(results['skip_bet'].sum()) if 'skip_bet' in results.columns else 0
    }

raw_metrics = evaluate(raw_results, active_only=False)
filtered_metrics_all = evaluate(filtered_results, active_only=False)
filtered_metrics_active = evaluate(filtered_results, active_only=True)

print("Raw Evaluation Metrics:")
print(raw_metrics)

print("\nFiltered Evaluation Metrics (all rows, adjusted probabilities):")
print(filtered_metrics_all)

print("\nFiltered Evaluation Metrics (active only, skip_bet removed):")
print(filtered_metrics_active)

# -----------------------------
# BANKROLL SIMULATION
# -----------------------------
raw_bankroll, raw_bankroll_summary = simulate_bankroll(raw_results, starting_bankroll=1000.0, flat_unit=10.0, active_only=False)
filtered_bankroll, filtered_bankroll_summary = simulate_bankroll(filtered_results, starting_bankroll=1000.0, flat_unit=10.0, active_only=True)

print("\nBankroll Simulation — Raw Model:")
print(raw_bankroll_summary)

print("\nBankroll Simulation — Filtered Active Bets:")
print(filtered_bankroll_summary)

if not raw_bankroll.empty:
    raw_bankroll.to_csv("outputs/model_validation/bankroll_raw_model.csv", index=False)

if not filtered_bankroll.empty:
    filtered_bankroll.to_csv("outputs/model_validation/bankroll_filtered_active.csv", index=False)

if not df.empty:
    print("\nSharpEdge Feature Layer Preview:")
    preview_cols = [
        col for col in [
            'prediction_date',
            'player',
            'market',
            'line',
            'side',
            'sharpedge_prob',
            'sharpedge_prob_filtered',
            'skip_bet',
            'safety_filter_tags',
            'hit'
        ] if col in df.columns
    ]
    print(df[preview_cols].tail(10))

    output_path = "outputs/model_validation/rolling_window_filtered_predictions.csv"
    df.to_csv(output_path, index=False)
    print(f"\nSaved filtered predictions to: {output_path}")
